      <description>&lt;p&gt;&#xD;&#xA;&lt;script src=&#34;https://jennifer.sh/scripts/tabs.js&#34;&gt;&lt;/script&gt;&#xD;&#xA;&lt;style&gt;&#xD;&#xA; &#xD;&#xA;  .tab {&#xD;&#xA;    width: 100%;&#xD;&#xA;    display: block;&#xD;&#xA;    overflow: hidden;&#xD;&#xA;    border: none;&#xD;&#xA;    background-color: none;&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA; &#xD;&#xA;  .tab button {&#xD;&#xA;    width: 25%;&#xD;&#xA;    background-color: #8EE691;&#xD;&#xA;    float: left;&#xD;&#xA;    border: none;&#xD;&#xA;    outline: none;&#xD;&#xA;    cursor: pointer;&#xD;&#xA;    padding: 14px 16px;&#xD;&#xA;    transition: 0.3s;&#xD;&#xA;    font-size: 20px;&#xD;&#xA;    font-family: &#39;Trebuchet MS&#39;, sans-serif;&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA; &#xD;&#xA;  .tab button:hover {&#xD;&#xA;    background-color: #6FB371;&#xD;&#xA;    color: #EEE;&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA; &#xD;&#xA;  .tab button.active {&#xD;&#xA;    background-color: #7ECC81;&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA; &#xD;&#xA;  .tabcontent {&#xD;&#xA;    background-color: #7ECC81;&#xD;&#xA;    display: none;&#xD;&#xA;    width:100%;&#xD;&#xA;    height: auto;&#xD;&#xA;    padding: 20px 0;&#xD;&#xA;    border: none;&#xD;&#xA;    font-size: 1.5vw;&#xD;&#xA;    text-align: left;&#xD;&#xA;  }&#xD;&#xA;&lt;/style&gt;&#xA;&lt;style&gt;&#xD;&#xA;   &#xD;&#xA;  &#xD;&#xA;  .gallery {&#xD;&#xA;    height: auto;&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;  .gallery li{&#xD;&#xA;    width: 100%;&#xD;&#xA;    height: auto;&#xD;&#xA;    list-style-type: none;&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;  .gallery ul {&#xD;&#xA;    column-count: 4;&#xD;&#xA;    padding: 0 20px;&#xD;&#xA;    margin: 20px 0;&#xD;&#xA;    height: auto;&#xD;&#xA;    text-align: center;&#xD;&#xA;  }&#xD;&#xA;  &#xD;&#xA;  .gallery img{&#xD;&#xA;    margin: 0;&#xD;&#xA;    margin-top: 16px;&#xD;&#xA;    vertical-align: middle;&#xD;&#xA;    width: 100%;&#xD;&#xA;    height: auto;&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;   &#xD;&#xA;&#xD;&#xA;  .gallery ul {&#xD;&#xA;    column-count: