 color: #111;&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;  #education td {&#xD;&#xA;    border: none;&#xD;&#xA;    color: #111;&#xD;&#xA;  }&#xD;&#xA; &#xD;&#xA;  #IandH td {&#xD;&#xA;    border: none;&#xD;&#xA;    text-align: left;&#xD;&#xA;    vertical-align: top;&#xD;&#xA;    color: #111;&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;  h3 {&#xD;&#xA;    padding: 0;&#xD;&#xA;    margin: 0;&#xD;&#xA;  }&#xD;&#xA;  &#xD;&#xA;  table {&#xD;&#xA;    border-collapse: collapse;&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA; .tabimage {&#xD;&#xA;    margin: auto;&#xD;&#xA;  }&#xD;&#xA;  &#xD;&#xA;  .hoverable {&#xD;&#xA;    width: auto;&#xD;&#xA;    height: auto;&#xD;&#xA;    position: relative;&#xD;&#xA;    display: inline-block;&#xD;&#xA;    margin: 0;&#xD;&#xA;  }&#xD;&#xA;  .hoverable .hover-top {&#xD;&#xA;    display: none;&#xD;&#xA;    position: absolute;&#xD;&#xA;    top: 0;&#xD;&#xA;    left: 0;&#xD;&#xA;    z-index: 99;&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;  .tab button:hover .hover-top {&#xD;&#xA;    display: inline;&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;  .tab button:hover .tabimage {&#xD;&#xA;    opacity: 0.01;&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;  .tab button.active .hover-top {&#xD;&#xA;    display: inline;&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;  .tab button.active .tabimage {&#xD;&#xA;    opacity: 0.01;&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;  .tab {&#xD;&#xA;    width: 892px;&#xD;&#xA;    margin: auto;&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;  .tabcontent {&#xD;&#xA;    width: 892px;&#xD;&#xA;    margin: auto;&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;  .dateto {&#xD;&#xA;    vertical-align: bottom; &#xD;&#xA;    text-align: center;&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;  .PQs {&#xD;&#xA;    color: #111;&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;  .PQs li{&#xD;&#xA;    width: 100%;&#xD;&#xA;    height: auto;&#xD;&#xA;    list-style-type: none;&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;  .PQs ul {&#xD;&#xA;    padding: 0 20px;&#xD;&#xA;    margin: 20px 0;&#xD;&#xA;    height: auto;&#xD;&#xA;    text-align: center;&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;   &#xD;&#xA;&#xD;&#xA;  h3 {&#xD;&#xA;    font-size: 36px;&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;  #employment td.dateto {&#xD;&#xA;    padding: 16px 0;&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;  #employment td{&#xD;&#xA;    font-size: 32px;&#xD;&#xA;    text-align: left;&#xD;&#xA;    padding: 16px;&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;  #education td {&#xD;&#xA;    text-align: left;&#xD;&#xA;    padding: 16px;&#xD;&#xA;    font-size: 32px;&#xD;&#xA;  }&#xD;&#xA;  &#xD;&#xA;  .asterixtext {&#xD;&#xA;    padding: 16px; &#xD;&#xA;    font-size: 24px;&#34;&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;  .tab button {&#xD;&#xA;    font-size: 2.5vw;&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;  #skills {&#xD;&#xA;    display: none;&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;  #skills_mob {&#xD;&#xA;    display: block;&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;  #skills_mob td {&#xD;&#xA;    border: none;&#xD;&#xA;    text-align: left;&#xD;&#xA;    padding: 8px;&#xD;&#xA;    color: #111;&#xD;&#xA;    font-size: 32px;&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;  .PQs ul {&#xD;&#xA;    column-count: 3;&#xD;&#xA;    font-size: 32px;&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;  .PQs li {&#xD;&#xA;    padding: 10px 0;&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;  #IandH td {&#xD;&#xA;    padding: 0 20px;&#xD;&#xA;    font-size: 32px;&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;  /***** PC *****/&#xD;&#xA;  &#xD;&#xA;  @media only screen and (min-width: 992px) {&#xD;&#xA;&#xD;&#xA;    h3 {&#xD;&#xA;      font-size: 17px;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    #employment td.dateto {&#xD;&#xA;      padding: 8px 0;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    #employment td{&#xD;&#xA;      font-size: 16px;&#xD;&#xA;      text-align: justify;&#xD;&#xA;      padding: 8px;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    #education td {&#xD;&#xA;      text-align: justify;&#xD;&#xA;      padding: 8px;&#xD;&#xA;      font-size: 16px;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    .asterixtext {&#xD;&#xA;      padding: 8px; &#xD;&#xA;      font-size: 12px;&#34;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    .tab button {&#xD;&#xA;      font-size: 20px;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    #skills {&#xD;&#xA;      display: block;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    #skills td {&#xD;&#xA;      border: none;&#xD;&#xA;      text-align: left;&#xD;&#xA;      padding: 8px;&#xD;&#xA;      color: #111;&#xD;&#xA;      font-size: 16px;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    #skills_mob {&#xD;&#xA;      display: none;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    .PQs ul {&#xD;&#xA;      column-count: 5;&#xD;&#xA;      font-size: 20px;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    .PQs li {&#xD;&#xA;      padding: 10px 0;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    #IandH td {&#xD;&#xA;      padding: 0 20px;&#xD;&#xA;      font-size: 20px;&#xD;&#xA;    }&#xD;&#xA;  }&#xD;&#xA;&lt;/style&gt;&#xD;&#xA;&#xD;&#xA;&lt;h1&gt;CV&lt;/h1&gt;&#xD;&#xA;&lt;p&gt;I am currently looking for my next employemnt opportunity. My varied career demonstrates highly useful interdisciplinary scientific skills and knowledge; and a set of interpersonal and organisational skills that are applicable for many types of work. I have experience designing and building computational models; analysing and presenting data; and writing scientific reports. Being able to adapt my knowledge and skills to new situations with steep learning curves makes me suitable for work across many disciplines. The breadth of my knowledge coupled with my creativity enables me to produce innovative solutions to problems.&lt;/p&gt;</description>
